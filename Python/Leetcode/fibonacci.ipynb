   "source": [
    "### Leetcode problem no 509\n",
    "Link : https://leetcode.com/problems/fibonacci-number/"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "e1593c2e",
   "metadata": {},
   "outputs": [],
   "source": [
    "class Solution:\n",
    "    def fib(self, n: int) -> int:\n",
    "        #base case\n",
    "        if n==0 or n==1:\n",
    "            return n\n",
    "        \n",
    "        # recursive case\n",
    "        return self.fib(n-1) + self.fib(n-2)"
   ]
  }
