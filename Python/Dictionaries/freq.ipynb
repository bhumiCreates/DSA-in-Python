     "output_type": "stream",
     "text": [
      "2 is present 2 times\n",
      "3 is present 3 times\n",
      "4 is present 1 times\n",
      "5 is present 1 times\n",
      "42 is present 1 times\n",
      "31 is present 1 times\n",
      "1 is present 1 times\n"
     ]
    }
   ],
   "source": [
    "list1=[2,3,4,5,2,42,31,3,1,3]\n",
    "freq={}\n",
    "\n",
    "for i in list1:\n",
    "    if i in freq:\n",
    "        freq[i]+=1\n",
    "    else:\n",
    "        freq[i]=1\n",
    "\n",
    "for i in freq:\n",
    "    print(f\"{i} is present {freq[i]} times\")\n"
   ]
  }
